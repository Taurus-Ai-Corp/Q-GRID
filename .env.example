# Hedera Configuration (TESTNET)
HEDERA_ACCOUNT_ID=0.0.YOUR_ACCOUNT_ID
HEDERA_PRIVATE_KEY=YOUR_DER_ENCODED_PRIVATE_KEY
HEDERA_PUBLIC_KEY=YOUR_DER_ENCODED_PUBLIC_KEY
HEDERA_NETWORK=testnet

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/qgrid
DB_HOST=localhost
DB_PORT=5432
DB_USER=qgrid_user
DB_PASSWORD=your_secure_password
DB_NAME=qgrid

# X402 Payment Service
X402_API_KEY=your_x402_api_key
X402_ENDPOINT=https://api.x402.example.com

# Stripe (Optional - for future billing)
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx

# Application
NODE_ENV=development
PORT=3000
VITE_API_URL=http://localhost:3000

# Replit Auth (if deploying on Replit)
REPLIT_AUTH_SECRET=your_auth_secret

# Logging
LOG_LEVEL=info

# PQC Configuration
PQC_ENABLED=true
PQC_MIGRATION_NETWORK=testnet
